# Pi Cloud Server - Environment Variables
# ========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ===================
# Flask Configuration
# ===================

# Application entry point
FLASK_APP=run.py

# Environment: development, testing, or production
FLASK_ENV=development

# Debug mode: 1 for development, 0 for production
FLASK_DEBUG=1

# Secret key for session management and security
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-very-long-random-string-in-production

# ========================
# Database Configuration
# ========================

# PostgreSQL connection URL format:
# postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://picloud:your_secure_password@localhost:5432/picloud_db

# Individual database settings (alternative to DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=picloud_db
# DB_USER=picloud
# DB_PASSWORD=your_secure_password

# ======================
# Storage Configuration
# ======================

# Path where uploaded files will be stored
# Use absolute path for production
STORAGE_PATH=./storage

# Maximum file size in bytes (default: 100MB = 104857600)
MAX_FILE_SIZE=104857600

# Allowed file extensions (comma-separated, or * for all)
ALLOWED_EXTENSIONS=*

# ======================
# Server Configuration
# ======================

# Host to bind the server to
# Use 0.0.0.0 to allow external connections
# Use 127.0.0.1 for localhost only
HOST=0.0.0.0

# Port to run the server on
PORT=5000

# ======================
# Logging Configuration
# ======================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (leave empty to log to console only)
LOG_FILE=./logs/picloud.log

# ===================
# Optional: API Key
# ===================

# Uncomment and set to enable API key authentication
# API_KEY=your-api-key-here

# ===================
# Optional: ngrok
# ===================

# ngrok authtoken (for automatic tunnel setup)
# NGROK_AUTHTOKEN=your-ngrok-authtoken
